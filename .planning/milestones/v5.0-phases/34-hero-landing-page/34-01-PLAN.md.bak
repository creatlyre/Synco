  <action>
Add new test methods to the existing `TestLandingPage` class in `tests/test_go_to_market.py`. Add them after the existing `test_landing_page_has_features` method (around line 66).

**New tests to add:**

```python
def test_landing_page_has_social_proof(self, test_client):
    """Social proof section with testimonials exists."""
    resp = test_client.get("/")
    html = resp.text
    assert 'id="social-proof"' in html

def test_landing_page_has_testimonials(self, test_client):
    """At least one testimonial is rendered."""
    resp = test_client.get("/")
    html = resp.text.lower()
    # Check for testimonial author names (hardcoded in i18n)
    assert "anna" in html or "tomek" in html

def test_landing_page_has_og_tags(self, test_client):
    """Open Graph meta tags present for social sharing."""
    resp = test_client.get("/")
    html = resp.text
    assert 'property="og:title"' in html
    assert 'property="og:description"' in html
    assert 'name="twitter:card"' in html

def test_landing_page_has_dual_cta(self, test_client):
    """Landing page has at least two CTAs linking to auth/login."""
    resp = test_client.get("/")
    html = resp.text
    # Count occurrences of auth/login hrefs
    import re
    cta_count = len(re.findall(r'href="/auth/login"', html))
    assert cta_count >= 2, f"Expected at least 2 auth/login CTAs, found {cta_count}"

def test_landing_page_has_trust_indicators(self, test_client):
    """Trust indicators (privacy, speed, open source) are present."""
    resp = test_client.get("/")
    html = resp.text.lower()
    # Check for trust badge content (any locale)
    assert "open source" in html or "otwarty" in html or "open" in html
```

Do NOT modify or remove any existing test methods. Only ADD new ones inside the `TestLandingPage` class.
